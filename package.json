{
  "name": "fitness-tracker",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace @athletica/mobile run start",
    "dev:api": "npm --workspace @athletica/api run dev",
    "start:api": "npm --workspace @athletica/api run start",
    "build:shared": "npm run build --workspace @athletica/shared",
    "build:api": "npm run build:shared && npm run build --workspace @athletica/api",
    "build": "npm run build:api",
    "lint": "npm run lint --workspaces --if-present",
    "seed": "npm --workspace @athletica/api run seed"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

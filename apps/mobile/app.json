{
  "expo": {
    "name": "Athletica",
    "slug": "athletica-fitness-tracker",
    "scheme": "athletica",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#06070A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.athletica.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#06070A"
      },
      "package": "com.athletica.mobile"
    },
    "extra": {
      "apiUrl": "http://localhost:4000/api/v1"
    }
  }
}
